{
  "name": "claude-electron",
  "productName": "POWER-AGENT",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w node-pty",
    "dist": "electron-builder --mac --arm64 --x64",
    "build:zip": "electron-builder --mac zip --arm64 --x64",
    "build:dmg": "electron-builder --mac dmg --arm64 --x64",
    "doctor": "bash ./scripts/doctor.sh",
    "reset:state": "bash ./scripts/reset-macos-state.sh",
    "deploy": "bash ./scripts/deploy.sh"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "cron-parser": "^4.9.0",
    "node-cron": "^3.0.3",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "20.x",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.luismi.claude-novak",
    "productName": "POWER-AGENT",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "files": [
      "main.js",
      "telegram-bridge.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "viewer.html",
      "viewer-renderer.js",
      "viewer-preload.js",
      "headless-runners.js",
      "tasks-manager.html",
      "tasks-manager-renderer.js",
      "tasks-manager-preload.js",
      "automation-chat.html",
      "automation-chat-renderer.js",
      "automation-chat-preload.js",
      "automation-pty.html",
      "automation-pty-renderer.js",
      "automation-pty-preload.js",
      "scheduler/**/*",
      "automations/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Dictado por voz con Whisper local.",
        "NSApplicationSupportsSecureRestorableState": true
      }
    },
    "directories": {
      "output": "dist"
    }
  }
}
